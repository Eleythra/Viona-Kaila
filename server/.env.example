PORT=3001

# Geç çıkış formunda “bugün” eşiği (geçmiş tarih reddi). IANA zaman dilimi; varsayılan Europe/Istanbul.
# HOTEL_TIMEZONE=Europe/Istanbul
# HOTEL_TZ=Europe/Istanbul

# --- Admin API (zorunlu, üretim) ---
# Güçlü rastgele değer (ör. openssl rand -hex 32). Git’e ve repoya yazmayın; Render Environment’a ekleyin.
ADMIN_API_TOKEN=replace_with_long_random_token
# Tarayıcıda sitenin açıldığı adres(ler): virgülle ayrılmış tam kök URL, sonda / yok.
# Örnek: statik site https://viona-kaila.onrender.com ise sadece onu yazın. API host’u (viona-node-api…) burada gerekmez.
# Üretim domain’leri (virgülle). Kod ayrıca localhost / 127.0.0.1 (5500, 3000, 5173) ile statik testi birleştirir.
# Yalnızca .env ile sınırlı kalmaz; lokal `npx serve` için ekstra satır gerekmez.
CORS_ALLOWED_ORIGINS=
# İsteğe bağlı: tüm alt alanlar (HTTPS origin’in hostname’i bu sonekle biterse izin). Örn. Vercel önizlemeleri + kendi domain:
# CORS_ALLOWED_ORIGIN_SUFFIXES=.vercel.app,.eleythra.com
CORS_ALLOWED_ORIGIN_SUFFIXES=
# Rate limit penceresi ve limitler
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=180
# ADMIN_RATE_LIMIT_MAX=80

# --- Azure Speech (sesli Viona: TTS + STT) ---
# Azure Portal → Kaynağınız → "Keys and endpoint" / "Anahtarlar ve uç nokta"
# KEY 1 veya KEY 2 değerini kopyalayın (tırnak kullanmayın, satır başında boşluk yok).
# Değişken ADLARI aşağıdaki gibi olmalı; kod sadece bunları okur:
AZURE_SPEECH_KEY=
# Bölge: kaynak oluştururken seçtiğiniz (ör. westeurope). Küçük harf, boşluksuz.
AZURE_SPEECH_REGION=westeurope
# Azure TTS/STT REST için ms (varsayılan 25000). STT iki denemeli olabilir; 0 = zaman sınırı yok.
# AZURE_SPEECH_FETCH_TIMEOUT_MS=25000

# Python asistan (uvicorn). Lokal: http://127.0.0.1:8010/api/chat
ASSISTANT_CHAT_ENDPOINT=https://YOUR_PYTHON_SERVICE.onrender.com/api/chat

# OpenAI (chat modulu)
OPENAI_API_KEY=your_openai_api_key
OPENAI_VECTOR_STORE_ID=vs_xxx
OPENAI_MODEL=gpt-4.1-mini
CHAT_DEBUG=0

# Supabase (admin / misafir / anket için gerekli; boşsa sunucu yine ayağa kalkar, bu uçlar 503 döner)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- WhatsApp Cloud API — operasyon bildirimleri (birebir mesaj; grup yok) ---
#
# WHATSAPP_ACCESS_TOKEN — Kalıcı (permanent) erişim token’ı kullanın:
#   Meta Business Suite → Ayarlar → İşletme ayarları → Kullanıcılar → Sistem kullanıcıları
#   → Create System User → uygulamayı ata → Generate token (WhatsApp / whatsapp_business_messaging
#   ve gerekli izinler). Bu, resmi “Create a System User and Generate a Permanent Access Token” akışıdır.
#   Geçici kullanıcı token’ları (ör. Graph API Explorer, kısa ömürlü User token) üretimde kullanmayın;
#   süre dolunca 401 / error 190 alırsınız.
#   Başvuru: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
#
WHATSAPP_ACCESS_TOKEN=
# Alternatif isim (ikisinden biri dolu olmalı; operasyon bildirimi ikisini de okur)
# WHATSAPP_CLOUD_ACCESS_TOKEN=
# WhatsApp → API kurulumu: gönderen iş telefonu için Phone number ID (sayısal)
WHATSAPP_PHONE_NUMBER_ID=
# Meta Business Account ID (gönderim için zorunlu değil; konsol referansı / dokümantasyon)
WHATSAPP_BUSINESS_ACCOUNT_ID=
# Webhook doğrulaması (gelen mesaj webhook’u için; yalnızca dışarıya template göndermek için zorunlu değil)
WHATSAPP_VERIFY_TOKEN=
# İsteğe bağlı Graph sürümü (varsayılan v21.0). Örn: v20.0 veya v21.0
# WHATSAPP_GRAPH_API_VERSION=v21.0
#
# --- Operasyon template bildirimleri (çoğu kodda sabit; Manager’da aynı adla onaylayın) ---
# viona_issue_notification (8 gövde parametresi) → WHATSAPP_TECH_RECIPIENTS
# viona_request_notification (8) → WHATSAPP_HK_RECIPIENTS
# viona_complaint_notification (6) → WHATSAPP_FRONT_RECIPIENTS
# Misafir bildirimi + geç çıkış (type: guest_notification | late_checkout): 7 gövde parametresi
# Varsayılan şablon adı: viona_guest_relation_notification
# İsterseniz override: WHATSAPP_GUEST_RELATION_TEMPLATE_NAME=viona_guest_relation_notification
# Eski ad (viona_guest_notification) hâlâ Manager’da ise: WHATSAPP_GUEST_NOTIFICATION_TEMPLATE=viona_guest_notification
# Dil: Turkish şablonlar için genelde tr (Manager’daki dil kodu ile aynı olmalı)
WHATSAPP_TEMPLATE_LANGUAGE=tr
# WHATSAPP_OPERATIONAL_TEMPLATE_LANGUAGE=tr
#
# Log öneki: [whatsapp_ops] — başarılı/başarısız ve Meta hata gövdesi
#
# Alıcılar: virgülle bir veya birden fazla (+905061449208,+905551112233). Her numaraya ayrı gönderim.
WHATSAPP_TECH_RECIPIENTS=
WHATSAPP_HK_RECIPIENTS=
# Şikâyet + misafir bildirimi / geç çıkış (ön büro; bu iki türde birleşik alıcı listesine dahil)
WHATSAPP_FRONT_RECIPIENTS=
# İsteğe bağlı: misafir bildirimi / geç çıkış alıcılarına eklenir
# WHATSAPP_RECEPTION_RECIPIENTS=
# WHATSAPP_GUEST_RELATIONS_RECIPIENTS=

# --- WhatsApp Grup Botu (whatsapp-web.js) ---
# Yeni önerilen teslim modu: group (varsayılan). Geri dönüş için cloud kullanılabilir.
WHATSAPP_OPERATIONAL_DELIVERY_MODE=group
# Cloud ile istek (viona_request_notification): Manager şablonunda kaç gövde değişkeni var?
# 8 = tam sıra (ad, oda, grup, tür, adet, tarih, saat, açıklama). Eski 4 değişkenli şablonda sıra kayması oluyorsa 4.
# Tam metin: group modu (üstte) — grup mesajı sunucudaki Türkçe biçimde gider; [ISTEK]/Ad: satırları Meta şablonundandır.
# WHATSAPP_CLOUD_REQUEST_PARAM_COUNT=8
# Botu aktif etmek için 1 yapın.
WHATSAPP_GROUP_BOT_ENABLED=0
# Oturumu sıfırla (yeni numara / tek sefer QR). API kapalıyken: npm run whatsapp:reset-session
# 7/24 tek süreç: pm2 start ecosystem.config.cjs — ayrıntı: docs/whatsapp-operasyon-7x24-tr.md
# Session kalıcılığı (sunucu restart sonrası tekrar QR zorunlu olmasın)
# WHATSAPP_GROUP_SESSION_DIR=runtime/whatsapp-session
# WHATSAPP_GROUP_CLIENT_ID=viona-operational
# WHATSAPP_GROUP_PUPPETEER_HEADLESS=true
#
# QR için Chromium gerekir. API’yi hangi dizinden başlatıyorsanız orada bir kez:
#   PUPPETEER_CACHE_DIR=.cache/puppeteer npx puppeteer browsers install chrome
# (server klasöründen: cd server && npm run puppeteer:install-chrome — o zaman cache server/.cache olur; tutarlılık için cwd’ye dikkat.)
# Sistem tarayıcısı kullanmak için (ör. Ubuntu):
# WHATSAPP_PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# İsteğe bağlı: önbellek klasörü (boşsa <cwd>/.cache/puppeteer)
# WHATSAPP_PUPPETEER_CACHE_DIR=.cache/puppeteer
#
# Web oturumu: QR kaç kez yenilenince vazgeçilsin? Boş veya 0 = sınırsız (önerilen).
# WhatsApp yine güvenlik için QR’ı periyodik yeniler; bunu kod kapatamaz.
# WHATSAPP_WWEB_QR_MAX_RETRIES=0
# WHATSAPP_WWEB_AUTH_TIMEOUT_MS=120000
# Gruba mesaj: bot ready olana kadar bekleme (ms, varsayılan 120000). Kısa isteklerde zaman aşımını artırın.
# WHATSAPP_GROUP_SEND_READY_WAIT_MS=120000
# detached Frame vb. için sendMessage yeniden deneme sayısı (varsayılan 8).
# WHATSAPP_GROUP_SEND_MAX_ATTEMPTS=8
# İlk gönderimden önce bekleme (ms, varsayılan 5000) — ready sonrası WA Web otursun.
# WHATSAPP_GROUP_PRE_SEND_SETTLE_MS=5000

# Sabit grup ID'leri (isimden dinamik routing yapılmaz).
# Teknik / HK / Ön Büro grup JID örneği: 1203xxxxxxxxxxxxxx@g.us
WHATSAPP_GROUP_ID_TEKNIK=
WHATSAPP_GROUP_ID_HK=
WHATSAPP_GROUP_ID_ON_BURO=

# Opsiyonel: doğrulama raporunda isim eşleşmesi için beklenen grup adları
# WHATSAPP_GROUP_NAME_TEKNIK=Teknik
# WHATSAPP_GROUP_NAME_HK=HK
# WHATSAPP_GROUP_NAME_ON_BURO=On Buro


# PDF raporu (admin) — boşsa metin şablonu kullanılır
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
# GEMINI_PDF_CACHE_TTL_MS=300000

# Render’da PDF: PUPPETEER_CACHE_DIR=.cache/puppeteer ve build’de
#   npx puppeteer browsers install chrome
# (ayrıntı: kök render.yaml ve server/docs/deploy-and-operations-report.md)
# PDF_GEMINI_TIMEOUT_MS=45000
# PDF_SET_CONTENT_TIMEOUT_MS=60000
