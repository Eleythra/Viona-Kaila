PORT=3001

# Node DNS: Supabase için `getaddrinfo EAI_AGAIN` önleme (virgülle IPv4). Üretimde de önerilir.
DNS_SERVERS=8.8.8.8,1.1.1.1
# Supabase isteklerinde geçici DNS için tekrar (varsayılan 8 deneme, taban gecikme 200 ms).
# SUPABASE_FETCH_DNS_RETRIES=8
# SUPABASE_FETCH_DNS_BASE_MS=200

# Geç çıkış formunda “bugün” eşiği (geçmiş tarih reddi). IANA zaman dilimi; varsayılan Europe/Istanbul.
# HOTEL_TIMEZONE=Europe/Istanbul
# HOTEL_TZ=Europe/Istanbul

# --- Admin API (zorunlu, üretim) ---
# Güçlü rastgele değer (ör. openssl rand -hex 32). Git’e ve repoya yazmayın; Render Environment’a ekleyin.
ADMIN_API_TOKEN=replace_with_long_random_token

# --- Saha ekip linkleri (admin/ops-hk.html, ops-tech.html, ops-front.html) ---
# Tam admin paneline erişim vermez; yalnızca ilgili kayıt listesi + durum güncelleme (X-Ops-Token).
# WhatsApp’ta: https://SİTE/admin/ops-hk.html#TOKEN — TOKEN, aşağıdaki OPS_LINK_TOKEN_HK ile birebir aynı metindir.
# Üretimde güçlü rastgele değer önerilir; hangi ekip olduğu dosya adından (ops-hk.html vb.) bellidir.
# OPS_LINK_TOKEN_HK=
# OPS_LINK_TOKEN_TECH=
# OPS_LINK_TOKEN_FRONT=
# Tarayıcıda sitenin açıldığı adres(ler): virgülle ayrılmış tam kök URL, sonda / yok.
# Örnek: statik site https://viona-kaila.onrender.com ise sadece onu yazın. API host’u (viona-node-api…) burada gerekmez.
# Üretim domain’leri (virgülle). Kod ayrıca localhost / 127.0.0.1 (5500, 3000, 5173) ile statik testi birleştirir.
# Yalnızca .env ile sınırlı kalmaz; lokal `npx serve` için ekstra satır gerekmez.
CORS_ALLOWED_ORIGINS=
# Rate limit penceresi ve limitler
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=180
# ADMIN_RATE_LIMIT_MAX=80

# --- Azure Speech (sesli Viona: TTS + STT) ---
# Azure Portal → Kaynağınız → "Keys and endpoint" / "Anahtarlar ve uç nokta"
# KEY 1 veya KEY 2 değerini kopyalayın (tırnak kullanmayın, satır başında boşluk yok).
# Değişken ADLARI aşağıdaki gibi olmalı; kod sadece bunları okur:
AZURE_SPEECH_KEY=
# Bölge: kaynak oluştururken seçtiğiniz (ör. westeurope). Küçük harf, boşluksuz.
AZURE_SPEECH_REGION=westeurope
# Azure TTS/STT REST için ms (varsayılan 25000). STT iki denemeli olabilir; 0 = zaman sınırı yok.
# AZURE_SPEECH_FETCH_TIMEOUT_MS=25000

# Python asistan (uvicorn). Lokal: http://127.0.0.1:8010/api/chat
ASSISTANT_CHAT_ENDPOINT=https://YOUR_PYTHON_SERVICE.onrender.com/api/chat

# OpenAI (chat modulu)
OPENAI_API_KEY=your_openai_api_key
OPENAI_VECTOR_STORE_ID=vs_xxx
OPENAI_MODEL=gpt-4.1-mini
CHAT_DEBUG=0

# Supabase (admin / misafir / anket için gerekli; boşsa sunucu yine ayağa kalkar, bu uçlar 503 döner)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- WhatsApp Cloud API — operasyon bildirimleri (birebir mesaj; grup yok) ---
#
# WHATSAPP_ACCESS_TOKEN — Kalıcı (permanent) erişim token’ı kullanın:
#   Meta Business Suite → Ayarlar → İşletme ayarları → Kullanıcılar → Sistem kullanıcıları
#   → Create System User → uygulamayı ata → Generate token (WhatsApp / whatsapp_business_messaging
#   ve gerekli izinler). Bu, resmi “Create a System User and Generate a Permanent Access Token” akışıdır.
#   Geçici kullanıcı token’ları (ör. Graph API Explorer, kısa ömürlü User token) üretimde kullanmayın;
#   süre dolunca 401 / error 190 alırsınız.
#   Başvuru: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
#
WHATSAPP_ACCESS_TOKEN=
# Alternatif isim (ikisinden biri dolu olmalı; operasyon bildirimi ikisini de okur)
# WHATSAPP_CLOUD_ACCESS_TOKEN=
# WhatsApp → API kurulumu: gönderen iş telefonu için Phone number ID (sayısal)
WHATSAPP_PHONE_NUMBER_ID=
# Meta Business Account ID (gönderim için zorunlu değil; konsol referansı / dokümantasyon)
WHATSAPP_BUSINESS_ACCOUNT_ID=
# Webhook doğrulaması (gelen mesaj webhook’u için; yalnızca dışarıya template göndermek için zorunlu değil)
WHATSAPP_VERIFY_TOKEN=
# İsteğe bağlı Graph sürümü (varsayılan v21.0). Örn: v20.0 veya v21.0
# WHATSAPP_GRAPH_API_VERSION=v21.0
#
# --- Operasyon template bildirimleri (Meta Business’ta gövde sırası kodla aynı olmalı; adı override edebilirsiniz) ---
# Varsayılan şablon adları (Manager’da aynı isimle onaylayın veya env ile değiştirin):
# WHATSAPP_TEMPLATE_FAULT=viona_issue_notification
# WHATSAPP_TEMPLATE_REQUEST=viona_request_notification
# WHATSAPP_TEMPLATE_COMPLAINT=viona_complaint_notification
# Arıza (8) → WHATSAPP_TECH_RECIPIENTS | İstek (8) → WHATSAPP_HK_RECIPIENTS
# Şikayet (6) + misafir bildirimi (7) + geç çıkış (7) → WHATSAPP_FRONT_RECIPIENTS (ön büro)
# Misafir / geç çıkış şablon adı: WHATSAPP_GUEST_RELATION_TEMPLATE_NAME veya viona_guest_relation_notification
# Eski ad: WHATSAPP_GUEST_NOTIFICATION_TEMPLATE=viona_guest_notification
# Dil: Turkish şablonlar için genelde tr (Manager’daki dil kodu ile aynı olmalı)
WHATSAPP_TEMPLATE_LANGUAGE=tr
# WHATSAPP_OPERATIONAL_TEMPLATE_LANGUAGE=tr
#
# Log öneki: [whatsapp_ops] — başarılı/başarısız ve Meta hata gövdesi
#
# Alıcılar: virgülle bir veya birden fazla (+905061449208,+905551112233). Her numaraya ayrı gönderim.
WHATSAPP_TECH_RECIPIENTS=
WHATSAPP_HK_RECIPIENTS=
# Ön büro: şikayet, misafir bildirimi, geç çıkış (virgülle)
WHATSAPP_FRONT_RECIPIENTS=
#
# Ekip işaretleme linkleri (WhatsApp grubunda / sabit mesajda):
#   Otomatik bildirim metni Meta şablonuyla gelir; şablona yeni satır/link eklemek Meta onayı gerektirir.
#   Pratik: WhatsApp grubunda «sabitlenmiş mesaj» veya grup açıklamasına şu üç adresi yazın (HTTPS + admin yolu):
#   …/admin/ops-hk.html  …/admin/ops-tech.html  …/admin/ops-front.html
#   (İsteğe bağlı #EKIP_SIFRESI ile oturum; şifreler OPS_LINK_TOKEN_* ile aynı olmalıdır.)
#
# İstek şablonunda 4 gövde değişkeni kullanan eski Meta şablonu varsa (sıra kayması önlemek için):
# WHATSAPP_CLOUD_REQUEST_PARAM_COUNT=4

# PDF raporu (admin) — boşsa metin şablonu kullanılır
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
# GEMINI_PDF_CACHE_TTL_MS=300000

# Render’da PDF: PUPPETEER_CACHE_DIR=.cache/puppeteer ve build’de
#   npx puppeteer browsers install chrome
# (ayrıntı: kök render.yaml ve server/docs/deploy-and-operations-report.md)
# PDF_GEMINI_TIMEOUT_MS=45000
# PDF_SET_CONTENT_TIMEOUT_MS=60000
