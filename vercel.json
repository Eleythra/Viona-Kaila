{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://viona-node-api.onrender.com/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/admin/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
