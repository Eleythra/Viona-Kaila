{
  "name": "viona-server",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "src/index.js",
  "scripts": {
    "test": "node --test src/modules/admin/reporting/*.test.mjs src/modules/admin/*.test.mjs src/services/operational-template-format.test.mjs src/lib/operational-quiet-hours.test.mjs",
    "test:quiet-hours": "node --test src/lib/operational-quiet-hours.test.mjs && python3 scripts/verify-quiet-hours-clock.py",
    "test:assistant": "PYTHONPATH=src .venv/bin/python -m pytest src/assistant/tests -q --tb=line",
    "dev": "node src/index.js",
    "puppeteer:install-chrome": "PUPPETEER_CACHE_DIR=.cache/puppeteer npx puppeteer browsers install chrome",
    "puppeteer:verify-chrome": "node scripts/verify-puppeteer-chrome.mjs",
    "seed:surveys-test": "node scripts/seed-survey-evaluations-test.mjs",
    "seed:surveys-test:clean": "node scripts/delete-survey-evaluations-seed.mjs",
    "verify:surveys-report": "node scripts/verify-survey-evaluations-report.mjs",
    "smoke:guest-request": "node scripts/smoke-guest-request-room-cleaning.mjs",
    "build:survey-locales": "node ../scripts/build-survey-i18n-overlay.mjs",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop viona-node-api",
    "pm2:logs": "pm2 logs viona-node-api --lines 100"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@supabase/supabase-js": "^2.100.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "openai": "^5.12.2",
    "puppeteer": "^24.40.0"
  }
}
