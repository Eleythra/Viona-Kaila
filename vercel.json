{
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "viona-admin.eleythra.com" }],
      "destination": "/admin/",
      "permanent": true
    },
    {
      "source": "/admin",
      "has": [{ "type": "host", "value": "viona-admin.eleythra.com" }],
      "destination": "/admin/",
      "permanent": true
    },
    {
      "source": "/feedbackfb_:path*",
      "destination": "/feedback/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/feedback/:path*",
      "destination": "/feedback.html"
    },
    {
      "source": "/feedback",
      "destination": "/feedback.html"
    },
    {
      "source": "/feedback/",
      "destination": "/feedback.html"
    },
    {
      "source": "/api/:path*",
      "destination": "https://viona-node-api.onrender.com/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/admin/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
