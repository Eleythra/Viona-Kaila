PORT=3001

# Node DNS: Supabase için `getaddrinfo EAI_AGAIN` önleme (virgülle IPv4). Üretimde de önerilir.
DNS_SERVERS=8.8.8.8,1.1.1.1
# Supabase isteklerinde geçici DNS için tekrar (varsayılan 8 deneme, taban gecikme 200 ms).
# SUPABASE_FETCH_DNS_RETRIES=8
# SUPABASE_FETCH_DNS_BASE_MS=200

# Geç çıkış formunda “bugün” eşiği (geçmiş tarih reddi). IANA zaman dilimi; varsayılan Europe/Istanbul.
# HOTEL_TIMEZONE=Europe/Istanbul
# HOTEL_TZ=Europe/Istanbul

# --- Admin API (zorunlu, üretim) ---
# Güçlü rastgele değer (ör. openssl rand -hex 32). Git’e ve repoya yazmayın; Render Environment’a ekleyin.
ADMIN_API_TOKEN=replace_with_long_random_token

# --- Saha ekip linkleri (admin/ops-hk.html, ops-tech.html, ops-front.html) ---
# Tam admin paneline erişim vermez; yalnızca ilgili kayıt listesi + durum güncelleme (X-Ops-Token).
# WhatsApp’ta: https://SİTE/admin/ops-hk.html#TOKEN — TOKEN, aşağıdaki OPS_LINK_TOKEN_HK ile birebir aynı metindir.
# Üretimde güçlü rastgele değer önerilir; hangi ekip olduğu dosya adından (ops-hk.html vb.) bellidir.
# OPS_LINK_TOKEN_HK=
# OPS_LINK_TOKEN_TECH=
# OPS_LINK_TOKEN_FRONT=
# Token’sız operasyon sayfaları (linkte #/?k/ şifre yok): güvenilen origin veya Vercel→Render proxy’sinde X-Forwarded-Host.
# Render’da 1 yapın; servisi yeniden başlatın. Güvenlik: URL’yi bilen herkes o ekip rolü gibi API çağırabilir — dahili kullanım.
# OPS_TRUST_OPS_PAGE_HEADER=1
# Tarayıcıda sitenin açıldığı adres(ler): virgülle ayrılmış tam kök URL, sonda / yok.
# Örnek: statik site https://viona-kaila.onrender.com ise sadece onu yazın. API host’u (viona-node-api…) burada gerekmez.
# Üretim domain’leri (virgülle). Kod ayrıca localhost / 127.0.0.1 (5500, 3000, 5173) ile statik testi birleştirir.
# Yalnızca .env ile sınırlı kalmaz; lokal `npx serve` için ekstra satır gerekmez.
CORS_ALLOWED_ORIGINS=
# Rate limit penceresi ve limitler
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=180
# ADMIN_RATE_LIMIT_MAX=80

# --- Azure Speech (sesli Viona: TTS + STT) ---
# Azure Portal → Kaynağınız → "Keys and endpoint" / "Anahtarlar ve uç nokta"
# KEY 1 veya KEY 2 değerini kopyalayın (tırnak kullanmayın, satır başında boşluk yok).
# Değişken ADLARI aşağıdaki gibi olmalı; kod sadece bunları okur:
AZURE_SPEECH_KEY=
# Bölge: kaynak oluştururken seçtiğiniz (ör. westeurope). Küçük harf, boşluksuz.
AZURE_SPEECH_REGION=westeurope
# Azure TTS/STT REST için ms (varsayılan 25000). STT iki denemeli olabilir; 0 = zaman sınırı yok.
# AZURE_SPEECH_FETCH_TIMEOUT_MS=25000
# İsteğe bağlı TTS/STT ek şifre (boş = kontrol yok): SPEECH_CLIENT_SECRET + istemci window.__VIONA_SPEECH_CLIENT_SECRET__

# Python asistan (uvicorn). Lokal: http://127.0.0.1:8010/api/chat
ASSISTANT_CHAT_ENDPOINT=https://YOUR_PYTHON_SERVICE.onrender.com/api/chat

# OpenAI (chat modulu)
OPENAI_API_KEY=your_openai_api_key
OPENAI_VECTOR_STORE_ID=vs_xxx
OPENAI_MODEL=gpt-4.1-mini
CHAT_DEBUG=0

# Supabase (admin / misafir / anket için gerekli; boşsa sunucu yine ayağa kalkar, bu uçlar 503 döner)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- WhatsApp Cloud API — operasyon bildirimleri (birebir mesaj; grup yok) ---
#
# WHATSAPP_ACCESS_TOKEN — Kalıcı (permanent) erişim token’ı kullanın:
#   Meta Business Suite → Ayarlar → İşletme ayarları → Kullanıcılar → Sistem kullanıcıları
#   → Create System User → uygulamayı ata → Generate token (WhatsApp / whatsapp_business_messaging
#   ve gerekli izinler). Bu, resmi “Create a System User and Generate a Permanent Access Token” akışıdır.
#   Geçici kullanıcı token’ları (ör. Graph API Explorer, kısa ömürlü User token) üretimde kullanmayın;
#   süre dolunca 401 / error 190 alırsınız.
#   Başvuru: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
#
WHATSAPP_ACCESS_TOKEN=
# Alternatif isim (ikisinden biri dolu olmalı; operasyon bildirimi ikisini de okur)
# WHATSAPP_CLOUD_ACCESS_TOKEN=
# WhatsApp → API kurulumu: gönderen iş telefonu için Phone number ID (sayısal)
WHATSAPP_PHONE_NUMBER_ID=
# Meta Business Account ID (gönderim için zorunlu değil; konsol referansı / dokümantasyon)
WHATSAPP_BUSINESS_ACCOUNT_ID=
# Webhook doğrulaması (gelen mesaj webhook’u için; yalnızca dışarıya template göndermek için zorunlu değil)
WHATSAPP_VERIFY_TOKEN=
# Render Environment: Meta App settings → Basic → App secret (tırnaksız yapıştırın).
# Doluysa gelen webhook POST imzası doğrulanır; boşsa doğrulama yok. Yanlışlıkla FACEBOOK_APP_SECRET adıyla eklerseniz o da okunur.
WHATSAPP_APP_SECRET=
# İsteğe bağlı Graph sürümü (varsayılan v21.0). Örn: v20.0 veya v21.0
# WHATSAPP_GRAPH_API_VERSION=v21.0
#
# --- Operasyon template bildirimleri (Meta Business’ta gövde sırası kodla aynı olmalı; adı override edebilirsiniz) ---
# Varsayılan şablon adları (Manager’da aynı isimle onaylayın veya env ile değiştirin):
# WHATSAPP_TEMPLATE_FAULT=viona_issue_notification
# WHATSAPP_TEMPLATE_REQUEST=viona_request_notification
# WHATSAPP_TEMPLATE_COMPLAINT=viona_complaint_notification
# Arıza (8) → WHATSAPP_TECH_RECIPIENTS | İstek (8) → WHATSAPP_HK_RECIPIENTS
# Şikayet (6) + misafir bildirimi (7) + geç çıkış (7) → WHATSAPP_FRONT_RECIPIENTS (ön büro)
# Misafir / geç çıkış şablon adı: WHATSAPP_GUEST_RELATION_TEMPLATE_NAME veya viona_guest_relation_notification
# Eski ad: WHATSAPP_GUEST_NOTIFICATION_TEMPLATE=viona_guest_notification
# Dil: Turkish şablonlar için genelde tr (Manager’daki dil kodu ile aynı olmalı)
WHATSAPP_TEMPLATE_LANGUAGE=tr
# WHATSAPP_OPERATIONAL_TEMPLATE_LANGUAGE=tr
#
# HK istek şablonunda Meta «Visit Website / Dynamic URL» butonu (Base URL admin kökü; suffix sunucu üretir):
# Meta’da Base URL tam olarak şu formda olmalı (sonunda / şart — yoksa ops-hk.html yanlış yapışır):
#   https://viona-admin.eleythra.com/admin/
# Sunucunun gönderdiği dinamik parça yalnızca: ops-hk.html?id=<uuid>  →  tam link …/admin/ops-hk.html?id=…
# Şablonda buton metni örn. «Panelde Aç»; gövde parametreleri değişmez. 1 yapınca istek (request) bildirimine
# bu suffix eklenir. Şablonda URL butonu yoksa veya sıra yanlışsa Meta hata döner — önce şablonu ekleyin.
# WHATSAPP_HK_PANEL_URL_BUTTON=1
# Arıza şablonunda aynı «Dynamic URL» düzeni (Base URL admin kökü): suffix `ops-tech.html?id=<uuid>`
# WHATSAPP_TECH_PANEL_URL_BUTTON=1
# Ön büro şablonları (şikâyet / misafir bildirimi / geç çıkış): suffix `ops-front.html?type=…&id=<uuid>`
# WHATSAPP_FRONT_PANEL_URL_BUTTON=1
#
# Log öneki: [whatsapp_ops] — başarılı/başarısız ve Meta hata gövdesi
#
# Alıcılar: virgülle bir veya birden fazla (+905061449208,+905551112233). Her numaraya ayrı gönderim.
WHATSAPP_TECH_RECIPIENTS=
WHATSAPP_HK_RECIPIENTS=
# Ön büro: şikayet, misafir bildirimi, geç çıkış (virgülle)
WHATSAPP_FRONT_RECIPIENTS=
#
# Ekip işaretleme linkleri (WhatsApp grubunda / sabit mesajda):
#   Otomatik bildirim metni Meta şablonuyla gelir; şablona yeni satır/link eklemek Meta onayı gerektirir.
#   Pratik: WhatsApp grubunda «sabitlenmiş mesaj» veya grup açıklamasına şu üç adresi yazın (HTTPS + admin yolu):
#   …/admin/ops-hk.html  …/admin/ops-tech.html  …/admin/ops-front.html
#   (İsteğe bağlı #EKIP_SIFRESI ile oturum; şifreler OPS_LINK_TOKEN_* ile aynı olmalıdır.)
#
# İstek şablonunda 4 gövde değişkeni kullanan eski Meta şablonu varsa (sıra kayması önlemek için):
# WHATSAPP_CLOUD_REQUEST_PARAM_COUNT=4

# --- Günlük operasyon PDF + WhatsApp (ör. 05:30 İstanbul; 3 ayrı PDF, ardışık gönderim) ---
# Render ücretsiz web: trafik yokken dyno uyur; hedef saatte iç timer yetmeyebilir. Çözümler:
#   (1) Kod: her /api isteğinde throttle ile uyarı — DAILY_OPERATION_REPORT_HTTP_PING
#   (2) Önerilen: Render’da `DAILY_OPERATION_REPORT_CRON_KEY` doldurun; cron-job.org’da “URL” olarak
#        kendi API adresinizi kullanın (örn. https://viona-node-api.onrender.com/... aşağıdaki gibi tam satır).
#   (3) Alternatif: POST …/api/internal/daily-operation-report + CRON_SECRET (Bearer)
#   (4) Paid always-on veya ek Render Cron Job servisi
# DAILY_OPERATION_REPORT_HTTP_PING=1
# DAILY_OPERATION_REPORT_HTTP_PING_THROTTLE_MS=45000
# Meta: departman başına Utility şablon (Header=document, gövde {{1}} tarih DD.MM.YYYY, {{2}} tesis adı).
# Varsayılan şablon adları (Manager’da farklıysa env ile override):
#   daily_operation_report_hk | daily_operation_report_tech | daily_operation_report_front
# WHATSAPP_TEMPLATE_DAILY_OPERATION_HK=daily_operation_report_hk
# WHATSAPP_TEMPLATE_DAILY_OPERATION_TECH=daily_operation_report_tech
# WHATSAPP_TEMPLATE_DAILY_OPERATION_FRONT=daily_operation_report_front
# Her gün o günün İstanbul «kayıt günü» verisi; sıra: HK PDF → (kısa bekleme) → Teknik PDF → (kısa bekleme) → Ön büro PDF.
# Alıcılar (önce günlük özel, yoksa operasyon listeleri — zaten tanımlıysa ayrı satır gerekmez):
#   WHATSAPP_DAILY_REPORT_HK_RECIPIENTS → günlük PDF yalnız buna (forma HK bildirimi WHATSAPP_HK_RECIPIENTS’tan ayrı); boşsa WHATSAPP_HK_RECIPIENTS
#   WHATSAPP_DAILY_REPORT_TECH_RECIPIENTS → yoksa WHATSAPP_TECH_RECIPIENTS
#   WHATSAPP_DAILY_REPORT_FRONT_RECIPIENTS → yoksa WHATSAPP_FRONT_RECIPIENTS
# Hepsi boşsa yedek: WHATSAPP_DAILY_REPORT_RECIPIENTS (üç gönderim de bu listeye gider — test için).
# DAILY_OPERATION_REPORT_HOTEL_NAME=Viona Kaila Beach Hotel
# İki gönderim arası bekleme (ms), Meta hız sınırı için; varsayılan 2000
# DAILY_OPERATION_REPORT_BETWEEN_SENDS_MS=2000
# Sunucu içi zamanlayıcı: 1 iken periyodik kontrol (varsayılan ~45 sn); tek instance önerilir
# DAILY_OPERATION_REPORT_ENABLED=1
# DAILY_OPERATION_REPORT_CRON=30 5 * * *
# DAILY_OPERATION_REPORT_HOUR=5
# DAILY_OPERATION_REPORT_MINUTE=30
# DAILY_OPERATION_REPORT_TICK_MS=45000
# Sunucu açılışında (ms) gecikmeyle: hedef saatten sonra aynı gün hâlâ gönderilmediyse bir kez dene
# DAILY_OPERATION_REPORT_STARTUP_CATCHUP_MS=5000
# Hedef saatin bulunduğu saat diliminde kaç dakika boyunca «interval» tetiklenebilir; 05:30 için 60 önerilir (05:30–05:59)
# DAILY_OPERATION_REPORT_FIRE_WINDOW_MIN=60
# DAILY_OPERATION_REPORT_TZ=Europe/Istanbul
# Yalnızca hazır departmanlar (şablon + alıcı); örn. sadece HK: hk — hepsi için satırı kaldır veya hk,tech,front
# DAILY_OPERATION_REPORT_SEGMENTS=hk
# Dış cron GET (dyno uyandırır + raporu dener): önce anahtarı env’e koyun, sonra cron-job.org’a tam URL verin.
# DAILY_OPERATION_REPORT_CRON_KEY=openssl_rand_hex_32_gibi_uzun_gizli
#
# cron-job.org — kısa adımlar (ücretsiz):
# 1) Render’da web servisinizin adresini kopyalayın (örn. https://viona-node-api.onrender.com — sizde farklı olabilir).
# 2) Bilgisayarda `openssl rand -hex 32` çalıştırın; çıkan uzun yazıyı Render → Environment → DAILY_OPERATION_REPORT_CRON_KEY olarak kaydedin.
# 3) Tek satır URL oluşturun (tırnak yok): https://ADRES/api/internal/daily-operation-report-cron?key=BURAYA_AYNI_UZUN_YAZI
#    Örnek: anahtar abc123 ise → .../daily-operation-report-cron?key=abc123
# 4) cron-job.org → Create cronjob → URL = bu tek satır → Method GET → Timezone Europe/Istanbul → her gün 05:30 (veya istediğiniz saat).
# POST manuel / dış cron: curl -sS -X POST "$API/api/internal/daily-operation-report" -H "Authorization: Bearer $CRON_SECRET" -H "Content-Type: application/json" -d '{}'
# CRON_SECRET=openssl_rand_hex_32_gibi_guclu_deger
# Idempotency: başarılı segment başına `server/.data/daily-operation-report/YYYY-MM-DD.hk|tech|front.sent`.
# Manuel veya `force:1` ile başarılı gönderimden sonra aynı gün iç zamanlayıcı (cron) o segmenti tekrar atmaz — çift mesaj önlenir.
# Otomatik denemek için: ilgili `.sent` dosyasını silin veya ertesi gün bekleyin. API zorla: `{"force":1}`.

# PDF raporu (admin) — boşsa metin şablonu kullanılır
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
# GEMINI_PDF_CACHE_TTL_MS=300000

# Render’da PDF: PUPPETEER_CACHE_DIR=.cache/puppeteer ve build’de
#   npx puppeteer browsers install chrome
# (ayrıntı: kök render.yaml ve server/docs/deploy-and-operations-report.md)
# PDF_GEMINI_TIMEOUT_MS=45000
# PDF_SET_CONTENT_TIMEOUT_MS=60000
