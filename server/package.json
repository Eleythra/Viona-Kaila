{
  "name": "viona-server",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "src/index.js",
  "scripts": {
    "test": "node --test src/modules/admin/reporting/*.test.mjs src/modules/admin/*.test.mjs",
    "test:assistant": "PYTHONPATH=src .venv/bin/python -m pytest src/assistant/tests -q --tb=line",
    "dev": "node src/index.js",
    "puppeteer:install-chrome": "PUPPETEER_CACHE_DIR=.cache/puppeteer npx puppeteer browsers install chrome",
    "puppeteer:verify-chrome": "node scripts/verify-puppeteer-chrome.mjs",
    "seed:surveys-test": "node scripts/seed-survey-evaluations-test.mjs",
    "seed:surveys-test:clean": "node scripts/delete-survey-evaluations-seed.mjs",
    "verify:surveys-report": "node scripts/verify-survey-evaluations-report.mjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@supabase/supabase-js": "^2.100.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "openai": "^5.12.2",
    "puppeteer": "^24.40.0"
  }
}
